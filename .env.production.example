POSTGRES_DB=DroneMarketDB_Prod
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

ASPNETCORE_ENVIRONMENT=Production
DOMAIN=example.com
LETSENCRYPT_EMAIL=ops@example.com
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ISSUER=DroneMarketAPI_Prod
JWT_AUDIENCE=DroneMarketFrontend_Prod

ALLOWED_ORIGIN_0=https://example.com
ALLOWED_ORIGIN_1=https://www.example.com
FRONTEND_BASE_URL=https://example.com

CONTACT_RECIPIENT_EMAIL=info@dronepazar.com
CONTACT_SENDER_EMAIL=info@dronepazar.com
CONTACT_SENDER_NAME=DronePazar Iletisim

RUN_MIGRATIONS_ON_STARTUP=true
RUN_SEED_ON_STARTUP=false
ENABLE_PASSWORD_RESET=true
ENABLE_SWAGGER=false
VITE_API_URL=
