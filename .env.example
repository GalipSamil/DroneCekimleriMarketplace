POSTGRES_DB=DroneMarketDB_Dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=dev-local-jwt-secret-2026-03-31-minimum-32-bytes-ok
JWT_ISSUER=DroneMarketAPI
JWT_AUDIENCE=DroneMarketFrontend

ALLOWED_ORIGIN_0=http://localhost
ALLOWED_ORIGIN_1=http://localhost:80
ALLOWED_ORIGIN_2=http://localhost:8080
FRONTEND_BASE_URL=http://localhost

CONTACT_RECIPIENT_EMAIL=info@dronepazar.com
CONTACT_SENDER_EMAIL=info@dronepazar.com
CONTACT_SENDER_NAME=DronePazar Iletisim

RUN_MIGRATIONS_ON_STARTUP=true
RUN_SEED_ON_STARTUP=true
ENABLE_PASSWORD_RESET=true
ADMIN_EMAIL=admin@drone.com
ADMIN_PASSWORD=Admin+1234

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_EMAIL=auth@dronepazar.com
EMAIL_FROM_NAME=DronePazar
EMAIL_ENABLE_SSL=true
EMAIL_USE_DEFAULT_CREDENTIALS=false
