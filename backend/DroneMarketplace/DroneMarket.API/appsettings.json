{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StartupTasks": {
    "RunMigrationsOnStartup": false,
    "RunSeedOnStartup": false,
    "RunDemoDataSeed": false
  },
  "Features": {
    "EnablePasswordReset": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DroneMarketDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "SET_VIA_ENVIRONMENT_VARIABLE",
    "Issuer": "DroneMarketAPI",
    "Audience": "DroneMarketFrontend",
    "ExpiryMinutes": 1440
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:5174",
    "http://localhost:4173",
    "http://localhost:4174"
  ]
}
