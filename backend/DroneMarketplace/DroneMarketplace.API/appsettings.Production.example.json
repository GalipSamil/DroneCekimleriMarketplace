{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "api.example.com,example.com",
  "Features": {
    "EnablePasswordReset": true,
    "EnableSwagger": false
  },
  "FrontendBaseUrl": "https://example.com",
  "ContactSettings": {
    "RecipientEmail": "info@dronepazar.com",
    "SenderEmail": "info@dronepazar.com",
    "SenderName": "DronePazar Iletisim"
  },
  "DataProtection": {
    "KeyPath": "/app/data-protection-keys"
  },
  "EmailSettings": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "smtp-user@example.com",
    "Password": "SMTP_PASSWORD_HERE",
    "FromEmail": "auth@dronepazar.com",
    "FromName": "DronePazar",
    "EnableSsl": true,
    "UseDefaultCredentials": false
  },
  "StartupTasks": {
    "RunMigrationsOnStartup": false,
    "RunSeedOnStartup": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_PG_HOST;Port=5432;Database=DroneMarketDB_Prod;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=false"
  },
  "JwtSettings": {
    "Secret": "SET_A_LONG_RANDOM_SECRET_HERE",
    "Issuer": "DroneMarketAPI_Prod",
    "Audience": "DroneMarketFrontend_Prod",
    "ExpiryMinutes": 1440
  },
  "AllowedOrigins": [
    "https://example.com",
    "https://www.example.com"
  ]
}
